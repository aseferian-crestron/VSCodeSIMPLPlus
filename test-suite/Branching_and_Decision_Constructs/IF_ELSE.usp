#SYMBOL_NAME "Test_IF_ELSE"
#DEFAULT_VOLATILE

STRING_INPUT IN$[100];

FUNCTION Main()
{
    STRING Y$[100];
    INTEGER X;
    
    IF (IN$ = "STRING1")
    {
    X=5;
    Y$ = IN$;
    }
    ELSE
    {
    X=6;
    Y$ = "";
    }
    IF (IN$ = "STRING1")
    {
    X=5;
    Y$ = IN$;
    }
    ELSE IF (IN$="STRING2")
    {
    X=6;
    Y$ = "";
    }
    ELSE
    {
    X = 7;
    Y$ = "ZZZ";
    }
}
