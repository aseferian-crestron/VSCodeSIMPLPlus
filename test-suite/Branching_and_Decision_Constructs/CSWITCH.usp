#SYMBOL_NAME "Test_CSWITCH"
#DEFAULT_VOLATILE

ANALOG_INPUT AIN;

FUNCTION Main()
{
    INTEGER X;
    
    CSWITCH( AIN )
    {
    CASE (2):
    {
    X = 0;
    break; // terminate this case statement block
    }
    CASE (3):
    {
    X = AIN;
    // continue executing to next case statement block ==> case(5)
    }
    CASE (5):
    {
    X = X + AIN + 1;
    break;
    }
    DEFAULT:
    {
    PRINT("Unknown command %d!\n", AIN);
    break;
    }
    }
}
