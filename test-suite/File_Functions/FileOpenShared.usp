#SYMBOL_NAME "Test_FileOpenShared"
#DEFAULT_VOLATILE

FUNCTION Main()
{
    SIGNED_INTEGER nFileHandle;
    StartFileOperations();
    nFileHandle = FileOpenShared("\\CF0\\MyFile", _O_RDONLY | _O_TEXT);
    IF (nFileHandle < 0)
        PRINT("Error opening MyFile\n");
    ELSE
        FileClose(nFileHandle);
    EndFileOperations();
}
